---
layout: layouts/base.njk
title: repos-manager
description: A single CLI tool to clone and sync all your Git repositories from GitHub, GitLab, Forgejo, Bitbucket, and Radicle.
---

<section class="hero animate">
  <h1>repos-manager</h1>
  <p class="tagline">One CLI to sync them all. Clone, update, and manage your Git repositories across every provider.</p>

  <div class="install-cmd" data-copy="git clone git@github.com:Dxsk/repos-manager.git && cd repos-manager && make install">
    <span class="prompt">$_</span> <span id="typing-target"></span><span class="cursor"></span>
  </div>

  <div class="buttons">
    <a href="#quickstart" class="btn btn-primary">Quick Start</a>
    <a href="/docs/getting-started/" class="btn btn-secondary">Docs</a>
  </div>
</section>

<section class="container">
  <div class="terminal-demo animate" id="terminal-demo">
    <div class="terminal-titlebar">
      <div class="terminal-dot red"></div>
      <div class="terminal-dot yellow"></div>
      <div class="terminal-dot green"></div>
      <span class="terminal-title">repos-manager</span>
    </div>
    <div class="terminal-body" id="terminal">
    </div>
  </div>
</section>

<script>
(function() {
  // Collect all elements to animate
  var targets = [];

  document.querySelectorAll('.animate').forEach(function(el) {
    el.classList.add('will-animate');
    targets.push(el);
  });

  document.querySelectorAll('.animate-stagger').forEach(function(parent) {
    Array.from(parent.children).forEach(function(child, i) {
      child.classList.add('will-animate');
      child.style.transitionDelay = (i * 0.08) + 's';
      targets.push(child);
    });
  });

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        if (entry.target.id === 'terminal-demo') {
          startTerminalDemo();
        }
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0 });

  targets.forEach(function(el) { observer.observe(el); });

  // Typing animation for install command
  var typingTarget = document.getElementById('typing-target');
  if (typingTarget) {
    var cmd = 'git clone git@github.com:Dxsk/repos-manager.git && cd repos-manager && make install';
    var i = 0;
    function typeChar() {
      if (i < cmd.length) {
        typingTarget.textContent += cmd.charAt(i);
        i++;
        var delay = 50 + Math.random() * 120;
        var ch = cmd.charAt(i - 1);
        // Pauses comme si on reflechit
        if (ch === ' ') delay += 80 + Math.random() * 180;
        if (ch === '&') delay += 50 + Math.random() * 80;
        if (ch === '.' || ch === ':' || ch === '/') delay += 40 + Math.random() * 70;
        if (ch === '@') delay += 100 + Math.random() * 150;
        // Parfois une longue hesitation
        if (Math.random() < 0.05) delay += 300 + Math.random() * 400;
        // Burst rapide (mots familiers)
        if (Math.random() < 0.2) delay = 20 + Math.random() * 30;
        setTimeout(typeChar, delay);
      }
    }
    setTimeout(typeChar, 1200);

  }


  // Terminal demo
  var terminalStarted = false;
  function startTerminalDemo() {
    if (terminalStarted) return;
    terminalStarted = true;

    var lines = [
      { type: 'cmd', text: '$ repos-manager sync --all', delay: 300 },
      { type: 'info', text: 'Fetching repository list from github.com...', delay: 900 },
      { type: 'info', text: 'Found 23 repositories', delay: 1300 },
      { type: 'output', text: '', delay: 1500 },
      { type: 'success', text: '  &#10003; Dxsk/dotenv (updated)', delay: 1700 },
      { type: 'success', text: '  &#10003; Dxsk/repos-manager (updated)', delay: 1900 },
      { type: 'success', text: '  &#10003; Dxsk/mtd (cloned)', delay: 2100 },
      { type: 'warn', text: '  &#9888; Dxsk/infra (dirty, skipped)', delay: 2300 },
      { type: 'success', text: '  &#10003; work-org/api (updated)', delay: 2500 },
      { type: 'output', text: '', delay: 2700 },
      { type: 'info', text: 'Done: 1 cloned, 3 updated, 1 skipped, 0 errors', delay: 2900 },
      { type: 'output', text: '', delay: 3300 },
      { type: 'cmd', text: '$ repos-manager status', delay: 3500 },
      { type: 'info', text: 'Scanning repos in ~/Documents...', delay: 4100 },
      { type: 'output', text: '', delay: 4300 },
      { type: 'warn', text: '  Dxsk/infra dirty', delay: 4500 },
      { type: 'success', text: '  Dxsk/mtd ahead (+1)', delay: 4700 },
      { type: 'output', text: '', delay: 4900 },
      { type: 'info', text: 'Total: 23 repos - 21 clean, 1 dirty, 1 ahead', delay: 5100 },
    ];

    var terminal = document.getElementById('terminal');
    if (!terminal) return;

    lines.forEach(function(line) {
      setTimeout(function() {
        var div = document.createElement('div');
        div.className = 'terminal-line';
        if (line.type === 'cmd') {
          div.innerHTML = '<span class="terminal-prompt">' + line.text.substring(0, 2) + '</span><span class="terminal-cmd">' + line.text.substring(2) + '</span>';
        } else {
          div.className += ' terminal-' + line.type;
          div.innerHTML = line.text;
        }
        terminal.appendChild(div);
        terminal.scrollTop = terminal.scrollHeight;
      }, line.delay);
    });
  }
})();
</script>

